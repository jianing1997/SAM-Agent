# SAM-Agent API keys
# Copy this file to .env and fill in your own keys.

# Required for ChatGPT-compatible LLM calls and RAG embeddings.
OPENAI_API_KEY=your_openai_or_chatanywhere_key

# Optional: required only when using Tavily web search.
TAVILY_API_KEY=your_tavily_key

# Optional: required only when using DeepSeek models.
DeepSeek_API_KEY=your_deepseek_key

# Optional: required only when using MolPort supplier lookup.
MOLPORT_API_KEY=your_molport_key
